
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users can read any profile (to find friends) but only write their own
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId;
      
      match /friends/{friendId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /requests/{requestId} {
        allow read, write: if request.auth.uid == userId || request.auth.uid == requestId;
      }
    }

    // Trips rules
    match /trips/{tripId} {
      // Robust creation rule: User must be authenticated, must be the creator, 
      // and must be included in the participant list to avoid locking themselves out.
      allow create: if isAuthenticated() && 
                    request.resource.data.createdBy == request.auth.uid &&
                    request.auth.uid in request.resource.data.participantIds;
      
      // Allow read/delete/update if user is a participant
      allow read, delete, update: if isAuthenticated() && 
        resource.data != null && 
        request.auth.uid in resource.data.participantIds;

      // Expenses subcollection
      match /expenses/{expenseId} {
        // Use get() to check the parent trip's participants
        allow read, write: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.participantIds;
      }
    }
  }
}
