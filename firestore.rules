
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if a user is a participant in a trip
    function isTripParticipant(tripData) {
      return isAuthenticated() && tripData != null && 
        'participantIds' in tripData && 
        request.auth.uid in tripData.participantIds;
    }

    // Users can read any profile (to find friends) but only write their own
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId;
      
      match /friends/{friendId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /requests/{requestId} {
        allow read, write: if request.auth.uid == userId || request.auth.uid == requestId;
      }
    }

    // Trips rules
    match /trips/{tripId} {
      // Allow create if authenticated. Creator MUST include themselves in participantIds (checked in app logic)
      allow create: if isAuthenticated();
      
      // Allow read/update/delete if user is a participant
      allow read, update, delete: if isTripParticipant(resource.data) || (request.resource != null && isTripParticipant(request.resource.data));
      
      // Expenses subcollection
      match /expenses/{expenseId} {
        allow read, write: if isTripParticipant(get(/databases/$(database)/documents/trips/$(tripId)).data);
      }
    }
  }
}
