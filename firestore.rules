
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users can read any profile (to find friends) but only write their own
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId;
      
      match /friends/{friendId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /requests/{requestId} {
        allow read, write: if request.auth.uid == userId || request.auth.uid == requestId;
      }
    }

    // Trips rules
    // Triggering deployment with this comment update.
    match /trips/{tripId} {
      // Allow create if authenticated
      allow create: if isAuthenticated();
      
      // Allow read/delete if user is a participant
      allow read, delete: if isAuthenticated() && 
        resource.data != null && 
        request.auth.uid in resource.data.participantIds;

      // Allow update if user was a participant or is becoming one
      allow update: if isAuthenticated() && 
        ((resource.data != null && request.auth.uid in resource.data.participantIds) || 
         (request.resource.data != null && request.auth.uid in request.resource.data.participantIds));
      
      // Expenses subcollection
      match /expenses/{expenseId} {
        // We use get() to check the parent trip's participants
        allow read, write: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.participantIds;
      }
    }
  }
}
