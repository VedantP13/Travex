
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users can read any profile (to find friends) but only write their own
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId;
      
      match /friends/{friendId} {
        // You can read and write your own friends list
        // OR a friend can write/delete their specific entry in your list to handle request handshakes
        allow read: if request.auth.uid == userId;
        allow write: if request.auth.uid == userId || request.auth.uid == friendId;
      }
      match /requests/{requestId} {
        // You can read/write your own requests
        // OR the sender (requestId) can write to your requests to send an invitation
        allow read, write: if request.auth.uid == userId || request.auth.uid == requestId;
      }
    }

    // Trips rules
    match /trips/{tripId} {
      allow create: if isAuthenticated() && 
                    request.resource.data.createdBy == request.auth.uid;
      
      allow read, delete, update: if isAuthenticated() && 
        resource.data != null && 
        request.auth.uid in resource.data.participantIds;

      match /expenses/{expenseId} {
        allow read, write: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.participantIds;
      }
    }
  }
}
