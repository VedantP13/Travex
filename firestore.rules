rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if a user is a participant in a trip
    function isTripParticipant(tripData) {
      return isAuthenticated() && 
        tripData.participants.any(p, p.userId == request.auth.uid);
    }

    // Users can read/write their own profile
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId;
      
      // Friends and requests subcollections
      match /friends/{friendId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /requests/{requestId} {
        allow read, write: if request.auth.uid == userId || request.auth.uid == requestId;
      }
    }

    // Trips rules
    match /trips/{tripId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isTripParticipant(resource.data) || isTripParticipant(request.resource.data);
      
      // Expenses subcollection
      match /expenses/{expenseId} {
        allow read, write: if isTripParticipant(get(/databases/$(database)/documents/trips/$(tripId)).data);
      }
    }
  }
}