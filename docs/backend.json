
{
  "entities": {
    "Trip": {
      "title": "Trip",
      "description": "A travel group containing participants and expenses.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "date": { "type": "string", "description": "The planned date or date range of the trip." },
        "status": { "type": "string", "enum": ["Active", "Completed", "Upcoming"] },
        "totalSpent": { "type": "number", "default": 0 },
        "yourBalance": { "type": "number", "default": 0 },
        "image": { "type": "string" },
        "participantIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of user IDs for efficient querying and permissions."
        },
        "participants": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/Participant"
          }
        }
      },
      "required": ["name", "participants", "participantIds"]
    },
    "Participant": {
      "title": "Participant",
      "description": "A member of a trip, can be an app user or a guest.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "isUser": { "type": "boolean" },
        "userId": { "type": "string" },
        "avatar": { "type": "string" },
        "familyMembers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Names of family members associated with this participant."
        }
      },
      "required": ["id", "name", "isUser"]
    },
    "Expense": {
      "title": "Expense",
      "description": "An individual transaction within a trip.",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "payerId": { "type": "string" },
        "payerName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "paymentType": { "type": "string", "enum": ["UPI", "Cash", "Card", "Net Banking"] },
        "category": { "type": "string" },
        "splitType": { "type": "string", "enum": ["equal_person", "equal_family", "custom", "just_me", "unsplit"] },
        "selectedIndividuals": { "type": "array", "items": { "type": "string" } },
        "customAmounts": {
          "type": "object",
          "description": "A map of participant IDs to their specific share."
        },
        "isItemized": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["description", "amount", "payerId", "date", "splitType"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Extended user information stored in Firestore.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "description": "High-quality profile image data (Base64) or URL." },
        "email": { "type": "string" },
        "isAnonymous": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Friendship": {
      "title": "Friendship",
      "description": "A relationship between two users.",
      "type": "object",
      "properties": {
        "friendId": { "type": "string" },
        "friendName": { "type": "string" },
        "friendPhoto": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "FriendRequest": {
      "title": "FriendRequest",
      "description": "An incoming request to be friends.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderPhoto": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/trips/{tripId}": {
      "schema": "Trip",
      "description": "Root collection for trips."
    },
    "/trips/{tripId}/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Subcollection for expenses within a trip."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection for storing custom user profile data."
    },
    "/users/{userId}/friends/{friendId}": {
      "schema": "Friendship",
      "description": "Subcollection for confirmed friends."
    },
    "/users/{userId}/requests/{requestId}": {
      "schema": "FriendRequest",
      "description": "Subcollection for incoming requests."
    }
  }
}
